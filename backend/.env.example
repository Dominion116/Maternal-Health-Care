PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Chat responses come from the locally trained intent-classification model.
# Run `npm run train-model` once before starting the server.

# JWT
JWT_SECRET=your-jwt-secret

# Frontend (used as redirect target in password-reset emails)
FRONTEND_URL=http://localhost:3001
